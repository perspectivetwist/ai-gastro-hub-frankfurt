{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "ai-gastro-hub-frankfurt.vercel.app"
        }
      ],
      "destination": "https://www.ki-gastronomie.com/staedte/frankfurt/$1",
      "permanent": true
    }
  ]
}
